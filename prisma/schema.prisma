// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           String         @id
  username     String         @unique
  email        String         @unique
  passwordHash String
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  profile      Profile?
  works        Work[]         @relation("UserWorks")
  savedWorks   SavedWork[]
  libraryFolders LibraryFolder[]
  likes        WorkLike[]
  comments     WorkComment[]
  views        WorkView[]
  notifications Notification[]
  passwordResetTokens PasswordResetToken[]
}

model Profile {
  id        Int      @id @default(autoincrement())
  userId    String   @unique
  nickname  String
  location  String
  bio       String
  avatarUrl String
  avatarKey String?
  notifyLikes Boolean @default(true)
  notifyComments Boolean @default(true)
  emailNotifications Boolean @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Work {
  id          Int         @id @default(autoincrement())
  authorId    String
  title       String
  category    String
  description String
  imageUrl    String
  imageKey    String?
  imageWidth  Int         @default(1200)
  imageHeight Int         @default(1500)
  tags        String
  featured    Boolean     @default(false)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  author      User        @relation("UserWorks", fields: [authorId], references: [id], onDelete: Cascade)
  savedBy     SavedWork[]
  likes       WorkLike[]
  comments    WorkComment[]
  views       WorkView[]
}

model SavedWork {
  id      Int      @id @default(autoincrement())
  userId  String
  workId  Int
  folderId Int?
  savedAt DateTime @default(now())
  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  work    Work     @relation(fields: [workId], references: [id], onDelete: Cascade)
  folder  LibraryFolder? @relation(fields: [folderId], references: [id], onDelete: SetNull)

  @@unique([userId, workId])
  @@index([folderId])
}

model LibraryFolder {
  id        Int      @id @default(autoincrement())
  userId    String
  name      String
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  savedWorks SavedWork[]

  @@unique([userId, name])
}

model Notification {
  id        Int      @id @default(autoincrement())
  userId    String
  text      String
  type      String   @default("system")
  href      String?
  actorId   String?
  workId    Int?
  unread    Boolean  @default(true)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model WorkLike {
  id        Int      @id @default(autoincrement())
  userId    String
  workId    Int
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  work      Work     @relation(fields: [workId], references: [id], onDelete: Cascade)

  @@unique([userId, workId])
}

model WorkComment {
  id        Int      @id @default(autoincrement())
  userId    String
  workId    Int
  text      String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  work      Work     @relation(fields: [workId], references: [id], onDelete: Cascade)
}

model WorkView {
  id        Int      @id @default(autoincrement())
  userId    String?
  workId    Int
  viewerKey String?
  viewedAt  DateTime @default(now())
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  work      Work     @relation(fields: [workId], references: [id], onDelete: Cascade)

  @@index([workId, viewedAt])
}

model PasswordResetToken {
  id        Int      @id @default(autoincrement())
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
}
